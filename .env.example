# Base URL of the luogu-saver-next backend (read-only API).
# Leave empty to use same-origin (when served behind a reverse proxy).
# Example:
# VITE_API_URL=http://localhost:3000
VITE_API_URL=

# Base URL of the judgement (陶片放逐) API.
# Separate origin from the main backend.
# Example:
# VITE_JUDGEMENT_API_URL=https://jdmt.luogu.me
VITE_JUDGEMENT_API_URL=
